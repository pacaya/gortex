{
  "mcpServers": {
    "gortex": {
      "command": "./gortex",
      "args": [
        "serve",
        "--index", ".",
        "--watch",
        "--web",
        "--embeddings",
        "--semantic"
      ],
      "env": {
        "GORTEX_INDEX_WORKERS": "${GORTEX_WORKERS:-8}"
      }
    }
  }
}
